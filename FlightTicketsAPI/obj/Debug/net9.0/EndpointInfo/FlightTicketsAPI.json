  "components": {
    "schemas": {
      "DtoFlightTicket": {
        "required": [
          "arrivalCode",
          "arrivalTime",
          "departureCode",
          "departureTime",
          "flightNumber",
          "price",
          "seat"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "flightNumber": {
            "minLength": 1,
            "pattern": "^[A-Z]{2}\\s\\d{1,4}$",
            "type": "string"
          },
          "departureCode": {
            "minLength": 1,
            "pattern": "^[A-Z]{3}$",
            "type": "string"
          },
          "arrivalCode": {
            "minLength": 1,
            "pattern": "^[A-Z]{3}$",
            "type": "string"
          },
          "seat": {
            "minLength": 1,
            "pattern": "^[A-Z]\\d{2}$",
            "type": "string"
          },
          "price": {
            "maximum": 200000,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "departureTime": {
            "type": "string",
            "format": "date-time"
          },
          "arrivalTime": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
